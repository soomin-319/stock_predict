#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
fetch_major_indices_and_listings_extended.py

FinanceDataReader(FDR)로 주요 미국 지수(확장 목록)와
NYSE, NASDAQ, AMEX 거래소 상장종목을 수집하여
normalize + validate 후 CSV 파일로 저장하는 스크립트입니다.

출력 컬럼: symbol,longName
"""

import pandas as pd
import FinanceDataReader as fdr
from tqdm import tqdm

# ---------------------------
# 사용자 설정
# ---------------------------
OUTPUT_CSV = 'symbol_meta.csv'   # 저장 파일명 변경
VALIDATE = True
VALIDATE_LIMIT = 99999
VALIDATE_START = '2016-01-01'

# ---------------------------
# 주요 지수 심볼 (확장)
# - 필요하면 여기에 더 추가하세요.
# - 지수 심볼은 FDR에서 인식 가능한 형식(예: '^SOX')으로 입력
# ---------------------------
MAJOR_INDICES = {
    'Dow Jones Industrial Average': '^DJI',
    'NASDAQ Composite': '^IXIC',
    'S&P 500': '^GSPC',
    'PHLX Semiconductor (SOX)': '^SOX',        # 필라델피아 반도체 지수
    'Russell 2000': '^RUT',
    'CBOE Volatility Index (VIX)': '^VIX',
    'NYSE Composite': '^NYA',
    'Wilshire 5000': '^W5000',
    'S&P MidCap 400': '^MID',
    'S&P SmallCap 600': '^SML',
    'Nasdaq‑100': '^NDX',
    'Russell 1000': '^RUI',
    'Wilshire 5000': '^W5000'
}

# 거래소 목록
EXCHANGES = ['NYSE', 'NASDAQ']
#EXCHANGES = ['AMEX']

# ---------------------------
# 유틸리티 함수들
# ---------------------------
def validate_symbol_with_fdr(symbol: str, start_date: str = '2018-01-01') -> bool:
    """FDR로 시계열 유효성 검사: Close 컬럼이 존재하고 비어있지 않은지 확인"""
    try:
        df = fdr.DataReader(symbol, start_date)
        if isinstance(df, pd.DataFrame) and 'Close' in df.columns and not df['Close'].dropna().empty:
            return True
        # 일부 심볼 표기 차이 대응 (예: / -> =)
        alt = symbol.replace('/','=')
        if alt != symbol:
            try:
                df2 = fdr.DataReader(alt, start_date)
                if isinstance(df2, pd.DataFrame) and 'Close' in df2.columns and not df2['Close'].dropna().empty:
                    return True
            except Exception:
                pass
    except Exception:
        pass
    return False

def normalize_listing_df(df: pd.DataFrame) -> pd.DataFrame:
    """거래소 상장목록을 표준화 (심볼, 롱네임만)"""
    if df is None or df.empty:
        return pd.DataFrame(columns=['symbol','longName'])
    df = df.copy()
    sym_col = None
    name_col = None
    for c in df.columns:
        lc = c.lower()
        if sym_col is None and lc in ('symbol','code','ticker','종목코드'):
            sym_col = c
        if name_col is None and lc in ('name','company','종목명'):
            name_col = c
    if sym_col is None:
        sym_col = df.columns[0]
    if name_col is None:
        name_col = df.columns[1] if len(df.columns) > 1 else sym_col
    out = pd.DataFrame()
    out['symbol'] = df[sym_col].astype(str).str.strip()
    out['longName'] = df[name_col].astype(str).str.strip()
    out = out.dropna(subset=['symbol']).drop_duplicates(subset=['symbol'])
    return out[['symbol','longName']]

# ---------------------------
# 메인 빌드 함수
# ---------------------------
def build_and_save(output_csv: str, validate: bool = True, validate_limit: int = 500, start_date: str = '2018-01-01'):
    records = []

    # 1) 주요 지수 추가
    print("[INFO] Adding major indices ...")
    for name, sym in MAJOR_INDICES.items():
        rec = {'symbol': sym, 'longName': name}
        if validate:
            ok = validate_symbol_with_fdr(sym, start_date=start_date)
            if not ok:
                print(f"[WARN] Validation failed for index {name} ({sym}), skipping index entry.")
                # 지수는 경우에 따라 FDR에서 바로 못읽을 수 있으므로 강제로 추가하려면 아래 주석 해제
                # records.append(rec)
                continue
        records.append(rec)

    # 2) 거래소 상장목록 추가
    for exch in EXCHANGES:
        print(f"[INFO] Fetching listing for {exch} ...")
        try:
            df_raw = fdr.StockListing(exch)
        except Exception as e:
            print(f"[WARN] Failed to fetch {exch}: {e}")
            continue
        df_norm = normalize_listing_df(df_raw)
        print(f"[INFO] {exch}: collected {len(df_norm)} symbols")
        rows = df_norm.to_dict('records')

        if validate:
            validated_rows = []
            checked = 0
            # tqdm은 많은 항목에서 진행상황을 보여줌
            for row in tqdm(rows, desc=f"Validating {exch}", total=len(rows)):
                if checked >= validate_limit:
                    # validate_limit에 도달하면 남은 항목은 검증 없이 추가
                    validated_rows.append(row)
                    continue
                sym = row['symbol']
                if validate_symbol_with_fdr(sym, start_date=start_date):
                    validated_rows.append(row)
                checked += 1
            rows = validated_rows

        records.extend(rows)

    if not records:
        print("[ERROR] No valid records fetched.")
        return pd.DataFrame()

    # 중복 제거 및 저장
    df_all = pd.DataFrame(records)
    df_all = df_all.drop_duplicates(subset=['symbol']).reset_index(drop=True)
    df_all.to_csv(output_csv, index=False, encoding='utf-8-sig')
    print(f"[OK] Saved {len(df_all)} records to {output_csv}")
    return df_all

# ---------------------------
# 실행부
# ---------------------------
if __name__ == "__main__":
    df_result = build_and_save(OUTPUT_CSV, validate=VALIDATE, validate_limit=VALIDATE_LIMIT, start_date=VALIDATE_START)
    if not df_result.empty:
        print("\nSample of saved records:")
        print(df_result.head(20).to_string(index=False))
